{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Wokwi: Bridge",
      "type": "shell",
      "command": "BRIDGE_PORT=3101 npm run bridge",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Wokwi bridge running on http://localhost:3101"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "Wokwi: GUI Serial Bridge",
      "type": "shell",
      "command": "BRIDGE_PORT=3101 npm run watch:gui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Connected to Wokwi RFC2217 serial server"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "Dashboard: Dev Server",
      "type": "shell",
      "command": "VITE_SENSOR_API_BASE=http://127.0.0.1:3101 npm run dev -- --port 3000 --strictPort",
      "options": {
        "cwd": "${workspaceFolder}/../sewerly"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontend"
      }
    },
    {
      "label": "System: Start GUI Slider Stack",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Wokwi: Bridge",
        "Wokwi: GUI Serial Bridge",
        "Dashboard: Dev Server"
      ],
      "problemMatcher": []
    }
  ]
}
