{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "MQTT: Start Broker",
      "type": "shell",
      "command": "docker-compose up -d mosquitto && echo '✅ MQTT Broker started on port 1883'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "mqtt"
      }
    },
    {
      "label": "MQTT: Stop Broker",
      "type": "shell",
      "command": "docker-compose down && echo '✅ MQTT Broker stopped'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "mqtt"
      }
    },
    {
      "label": "MQTT: Monitor Traffic",
      "type": "shell",
      "command": "docker exec -it manhole-mqtt-broker mosquitto_sub -t 'manhole/#' -v",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "mqtt"
      }
    },
    {
      "label": "MQTT: View Broker Logs",
      "type": "shell",
      "command": "docker logs -f manhole-mqtt-broker",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "mqtt"
      }
    },
    {
      "label": "Wokwi: Bridge",
      "type": "shell",
      "command": "BRIDGE_PORT=3101 npm run bridge",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Wokwi bridge running on http://localhost:3101"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "Wokwi: GUI Serial Bridge",
      "type": "shell",
      "command": "BRIDGE_PORT=3101 npm run watch:gui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Connected to Wokwi RFC2217 serial server"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "Dashboard: Dev Server",
      "type": "shell",
      "command": "VITE_SENSOR_API_BASE=http://127.0.0.1:3101 npm run dev -- --port 3000 --strictPort",
      "options": {
        "cwd": "${workspaceFolder}/../sewerly"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontend"
      }
    },
    {
      "label": "System: Start GUI Slider Stack",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Wokwi: Bridge",
        "Wokwi: GUI Serial Bridge",
        "Dashboard: Dev Server"
      ],
      "problemMatcher": []
    },
    {
      "label": "System: Start Complete Stack (with MQTT)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "MQTT: Start Broker",
        "System: Start GUI Slider Stack"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "System: Stop All Services",
      "type": "shell",
      "command": "docker-compose down && echo '✅ All services stopped. Press Ctrl+C in other terminals to stop Bridge and Dashboard.'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
