# Local bridge
BRIDGE_PORT=3001
SENSOR_STORAGE_BACKEND=firestore
LOCAL_CACHE_ENABLED=false

# API Key Authentication (REQ-003)
# Set to secure the bridge API endpoints
# Generate a strong random key: openssl rand -hex 32
API_KEY=your-secure-api-key-here
REQUIRE_API_KEY=true

# MQTT Configuration (REQ-007)
# MQTT broker for IoT communication
MQTT_BROKER=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=manhole
MQTT_LOCATION_ID=location_001

# Threshold Hysteresis Configuration (REQ-004)
# Prevents alert spam when values oscillate near thresholds
H2S_HYSTERESIS=1.0      # 1 ppm hysteresis for H2S
CH4_HYSTERESIS=50.0     # 50 ppm hysteresis for CH4
WATER_HYSTERESIS=2.0    # 2 cm hysteresis for water level

# Network Retry Configuration (REQ-006)
# Exponential backoff with jitter for reliable networking
MAX_RETRY_ATTEMPTS=5        # Maximum retry attempts
BASE_RETRY_DELAY=1000       # Base delay in milliseconds (1 second)
MAX_RETRY_DELAY=60000       # Maximum delay in milliseconds (60 seconds)
RETRY_JITTER_PERCENT=0.2    # Jitter percentage (±20%)
BACKOFF_MULTIPLIER=2.0      # Exponential backoff multiplier

# Firestore admin credentials
# Use either these env vars or a local serviceAccountKey.json file.
FIREBASE_PROJECT_ID=manhole-monitoring-e5d2b
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@manhole-monitoring-e5d2b.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIRESTORE_COLLECTION=sensor_readings

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
# Leave empty to disable Telegram alerts
TELEGRAM_BOT_TOKEN=8741837188:AAHrhu4Ft8UBpIG94gwBsU7CIqYFAM8Srxw
# Comma-separated list of chat IDs to receive alerts (e.g., 987654321,123456789)
TELEGRAM_CHAT_IDS=836634920

# Wokwi VS Code GUI serial forwarding
WOKWI_RFC2217_HOST=127.0.0.1
WOKWI_RFC2217_PORT=4000

