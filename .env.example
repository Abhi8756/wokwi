# Local bridge
BRIDGE_PORT=3001
SENSOR_STORAGE_BACKEND=firestore
LOCAL_CACHE_ENABLED=false

# Firestore admin credentials
# Use either these env vars or a local serviceAccountKey.json file.
FIREBASE_PROJECT_ID=manhole-monitoring-e5d2b
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@manhole-monitoring-e5d2b.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIRESTORE_COLLECTION=sensor_readings

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
# Leave empty to disable Telegram alerts
TELEGRAM_BOT_TOKEN=8741837188:AAHrhu4Ft8UBpIG94gwBsU7CIqYFAM8Srxw
# Comma-separated list of chat IDs to receive alerts (e.g., 987654321,123456789)
TELEGRAM_CHAT_IDS=836634920

# Wokwi VS Code GUI serial forwarding
WOKWI_RFC2217_HOST=127.0.0.1
WOKWI_RFC2217_PORT=4000

